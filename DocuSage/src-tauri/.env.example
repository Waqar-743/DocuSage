# ── DocuSage Environment Configuration ──────────────────────────────────
#
# MODEL_PATH (optional)
#   Absolute path to the directory containing your GGUF model files.
#   If unset, DocuSage searches common folders such as:
#     - <app folder>/models
#     - <cwd>/models
#     - <OS Documents folder>/DocuSage/models
#     - Windows drive roots like D:\DocuSage\models
#
#   Examples:
#     Linux / Codespace : MODEL_PATH=/home/codespace/models
#     macOS             : MODEL_PATH=/Users/you/models
#     Windows           : MODEL_PATH=C:\Users\you\models
#
MODEL_PATH=
