{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocuSage",
  "version": "0.5.3",
  "identifier": "com.docusage.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DocuSage",
        "width": 640,
        "height": 760,
        "minWidth": 420,
        "minHeight": 420,
        "visible": false,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
